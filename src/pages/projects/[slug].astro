---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { allProfiles, getProfile } from "../../lib/profiles";

export function getStaticPaths() {
  return allProfiles.map((profile) => ({
    params: { slug: profile.slug },
  }));
}

const { slug } = Astro.params;
const profile = getProfile(slug);
const { frontmatter } = profile;
const name = frontmatter.name ?? "";
const title = frontmatter.title ?? "";
const projects = frontmatter.projects ?? [];
---
<BaseLayout title={`${name} · Projects`} description={`${title} projects`}>
  <main class="container fade-in">
    <section class="hero">
      <div class="stagger">
        <div class="eyebrow">Portfolio</div>
        <h1>{name}</h1>
        <p class="tagline">Projects</p>
        <div class="links">
          <a class="button secondary" href={slug === "main" ? "/" : `/profiles/${slug}`}>
            Back to Profile
          </a>
        </div>
      </div>
      <div class="card">
        <h3>Project Highlights</h3>
        <p>
          A curated set of projects with brief summaries and direct links.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Projects</h2>
      </div>
      {projects.length ? (
        <div class="grid project-grid">
          {projects.map((project: any) => (
            <a
              class="project-card"
              href={project.url}
              target="_blank"
              rel="noreferrer"
              style={project.image ? `--project-image: url('${project.image}')` : ""}
            >
              <div class="project-card__content">
                <h3>{project.title}</h3>
                <p>{project.description}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <article class="card">
          <p>Add projects to this profile to see them here.</p>
        </article>
      )}
    </section>
  </main>

  <style>
    .project-grid {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }

    .project-card {
      position: relative;
      border-radius: var(--radius);
      min-height: 220px;
      padding: 24px;
      overflow: hidden;
      color: #fff;
      background:
        linear-gradient(160deg, rgba(15, 27, 43, 0.82), rgba(15, 27, 43, 0.35)),
        var(--project-image, linear-gradient(135deg, rgba(10, 127, 99, 0.55), rgba(241, 154, 62, 0.55)));
      background-size: cover;
      background-position: center;
      box-shadow: var(--shadow);
      border: 1px solid rgba(15, 27, 43, 0.12);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .project-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 26px 50px rgba(8, 14, 24, 0.2);
    }

    .project-card__content {
      position: relative;
      z-index: 1;
    }

    .project-card h3 {
      margin-bottom: 12px;
      color: #fff;
    }

    .project-card p {
      color: rgba(255, 255, 255, 0.88);
    }

    [data-theme="dark"] .project-card {
      background:
        linear-gradient(160deg, rgba(6, 10, 18, 0.85), rgba(6, 10, 18, 0.35)),
        var(--project-image, linear-gradient(135deg, rgba(63, 208, 178, 0.45), rgba(79, 117, 255, 0.45)));
      border-color: rgba(230, 238, 247, 0.16);
    }
  </style>
</BaseLayout>
