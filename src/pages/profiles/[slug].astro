---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProfile, getPublicProfiles } from "../../lib/profiles";

export function getStaticPaths() {
  return getPublicProfiles().map((profile) => ({
    params: { slug: profile.slug },
  }));
}

const { slug } = Astro.params;
const profile = getProfile(slug);
const { frontmatter, Content } = profile;
const name = frontmatter.name ?? "";
const title = frontmatter.title ?? "";
const location = frontmatter.location ?? "";
const links = frontmatter.links ?? {};
const resume = frontmatter.resume ?? "/resume.pdf";
const experience = frontmatter.experience ?? [];
const experienceFirst = experience.slice(0, 3);
const experienceRest = experience.slice(3);
const education = frontmatter.education ?? [];
const skills = frontmatter.skills ?? {};
const publications = frontmatter.publications ?? [];
const abstracts = frontmatter.abstracts ?? [];
const interests = frontmatter.interests ?? [];
const publicationsSorted = [...publications].sort((a, b) => (b.year ?? 0) - (a.year ?? 0));
const abstractsSorted = [...abstracts].sort((a, b) => (b.year ?? 0) - (a.year ?? 0));
const showProjects = false;
---
<BaseLayout title={`${name} · ${title}`} description={title}>
  <main class="container fade-in">
    <nav class="progress-rail" aria-label="Section progress">
      <a class="progress-link is-active" href="#experience" data-progress-link="experience">Experience</a>
      <a class="progress-link" href="#education" data-progress-link="education">Education</a>
      <a class="progress-link" href="#skills" data-progress-link="skills">Skills</a>
      <a class="progress-link" href="#publications" data-progress-link="publications">Publications</a>
      <a class="progress-link" href="#abstracts" data-progress-link="abstracts">Abstracts</a>
      <a class="progress-link" href="#interests" data-progress-link="interests">Interests</a>
    </nav>
    <section class="hero reveal-target">
      <div class="stagger">
        <div class="eyebrow">Portfolio</div>
        <h1>{name}</h1>
        <p class="tagline">
          {title} · {location}
        </p>
        <div class="links">
          {links.linkedin ? (
            <a class="button secondary" href={links.linkedin} target="_blank" rel="noreferrer">
              LinkedIn
            </a>
          ) : null}
          {links.email ? (
            <a class="button secondary" href={links.email}>
              Email
            </a>
          ) : null}
          {showProjects ? (
            <a class="button projects" href={`/projects/${slug}`}>
              Projects (Coming Soon)
            </a>
          ) : null}
          <a class="button" href={resume} download>
            Download Resume
          </a>
        </div>
      </div>
      <div class="card reveal-target">
        <h3>Summary</h3>
        <Content />
      </div>
    </section>

    <section class="section reveal-target" data-exp-mode="detailed" id="experience" data-progress-section="experience">
      <div class="section-header">
        <h2>Work Experience</h2>
        <div class="exp-view-toggle" role="group" aria-label="Work experience view mode">
          <button type="button" class="is-active" data-exp-view="detailed">Detailed</button>
          <button type="button" data-exp-view="compact">Compact</button>
        </div>
      </div>
      <div class="grid one experience-timeline">
        {experienceFirst.map((company: any) => (
          <article class="card experience-card reveal-target">
            <div class="card-row">
              <h3 class="card-title">
                {company.companyUrl ? (
                  <a href={company.companyUrl} target="_blank" rel="noreferrer">
                    {company.company}
                  </a>
                ) : (
                  company.company
                )}
              </h3>
              <p class="meta right">{company.location}</p>
            </div>
            {company.highlights?.length ? (
              <ul class="tags experience-highlights">
                {company.highlights.map((item: string) => (
                  <li class="tag">{item}</li>
                ))}
              </ul>
            ) : null}
            <div class="grid">
              {company.roles?.map((role: any) => (
                <div>
                  <div class="card-row">
                    <h3>
                      {role.roleUrl ? (
                        <a href={role.roleUrl} target="_blank" rel="noreferrer">
                          {role.title}
                        </a>
                      ) : (
                        role.title
                      )}
                    </h3>
                    <p class="meta right">
                      {role.start} — {role.end}
                    </p>
                  </div>
                  {role.highlights?.length ? (
                    <ul class="list role-highlights">
                      {role.highlights.map((item: string) => (
                        <li set:html={item}></li>
                      ))}
                    </ul>
                  ) : null}
                </div>
              ))}
            </div>
          </article>
        ))}
        {experienceRest.map((company: any) => (
          <article class="card experience-card experience-extra is-hidden reveal-target">
            <div class="card-row">
              <h3 class="card-title">
                {company.companyUrl ? (
                  <a href={company.companyUrl} target="_blank" rel="noreferrer">
                    {company.company}
                  </a>
                ) : (
                  company.company
                )}
              </h3>
              <p class="meta right">{company.location}</p>
            </div>
            {company.highlights?.length ? (
              <ul class="tags experience-highlights">
                {company.highlights.map((item: string) => (
                  <li class="tag">{item}</li>
                ))}
              </ul>
            ) : null}
            <div class="grid">
              {company.roles?.map((role: any) => (
                <div>
                  <div class="card-row">
                    <h3>
                      {role.roleUrl ? (
                        <a href={role.roleUrl} target="_blank" rel="noreferrer">
                          {role.title}
                        </a>
                      ) : (
                        role.title
                      )}
                    </h3>
                    <p class="meta right">
                      {role.start} — {role.end}
                    </p>
                  </div>
                  {role.highlights?.length ? (
                    <ul class="list role-highlights">
                      {role.highlights.map((item: string) => (
                        <li set:html={item}></li>
                      ))}
                    </ul>
                  ) : null}
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
      {experienceRest.length ? (
        <div class="section-actions">
          <button class="button more" type="button" data-exp-toggle>
            See more
          </button>
        </div>
      ) : null}
    </section>

    <section class="section reveal-target" id="education" data-progress-section="education">
      <div class="section-header">
        <h2>Education</h2>
      </div>
      <div class="grid two">
        {education.map((item: any) => (
          <article class="card reveal-target">
            <h3>{item.degree}</h3>
            <p class="meta">{item.university}</p>
            <p class="meta">
              {item.start} — {item.end}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="section reveal-target" id="skills" data-progress-section="skills">
      <div class="section-header">
        <h2>Skills</h2>
      </div>
      <div class="grid three">
        <article class="card reveal-target">
          <h3>Programming & AI</h3>
          <ul class="tags">
            {(skills.programming_ai ?? []).map((item: string) => (
              <li class="tag">{item}</li>
            ))}
          </ul>
        </article>
        <article class="card reveal-target">
          <h3>Cloud Tools</h3>
          <ul class="tags">
            {(skills.cloud_tools ?? []).map((item: string) => (
              <li class="tag">{item}</li>
            ))}
          </ul>
        </article>
        <article class="card reveal-target">
          <h3>Domain Expertise</h3>
          <ul class="tags">
            {(skills.domain_expertise ?? []).map((item: string) => (
              <li class="tag">{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section reveal-target" id="publications" data-progress-section="publications">
      <details class="collapse" data-filter="publications">
        <summary class="collapse-title">Publications</summary>
        <div class="filter-row">
          <span class="filter-label">Filter</span>
          <div class="segmented-filter" role="group" aria-label="Publications filter">
            <button type="button" class="is-active" data-first-author-toggle data-filter-mode="all">
              All
            </button>
            <button type="button" data-first-author-toggle data-filter-mode="first">First Author</button>
          </div>
        </div>
        <div class="grid two">
          {publicationsSorted.map((pub: any) => {
            const venue =
              `${pub.venue ?? ""}`.toLowerCase().includes("arxiv") ? "Preprint" : pub.venue;
            const isFirstAuthor = pub.effort === "high";
            return (
              <article
                class="card filter-item reveal-target"
                data-first-author={isFirstAuthor ? "true" : "false"}
              >
                <div class="card-row">
                  <h3>
                    {pub.link ? (
                      <a href={pub.link} target="_blank" rel="noreferrer">
                        {pub.title}
                      </a>
                    ) : (
                      pub.title
                    )}
                  </h3>
                  {isFirstAuthor ? <span class="effort-pill effort-first-author">First Author</span> : null}
                </div>
                <p class="meta">
                  {venue} · {pub.year}
                </p>
                <p>{pub.abstract}</p>
              </article>
            );
          })}
        </div>
      </details>
    </section>

    <section class="section reveal-target" id="abstracts" data-progress-section="abstracts">
      <details class="collapse" data-filter="abstracts">
        <summary class="collapse-title">Abstracts</summary>
        <div class="filter-row">
          <span class="filter-label">Filter</span>
          <div class="segmented-filter" role="group" aria-label="Abstracts filter">
            <button type="button" class="is-active" data-first-author-toggle data-filter-mode="all">
              All
            </button>
            <button type="button" data-first-author-toggle data-filter-mode="first">First Author</button>
          </div>
        </div>
        <div class="grid two">
          {abstractsSorted.map((item: any) => {
            const venue =
              `${item.venue ?? ""}`.toLowerCase().includes("arxiv") ? "Preprint" : item.venue;
            const isFirstAuthor = item.effort === "high";
            return (
              <article
                class="card filter-item reveal-target"
                data-first-author={isFirstAuthor ? "true" : "false"}
              >
                <div class="card-row">
                  <h3>
                    {item.link ? (
                      <a href={item.link} target="_blank" rel="noreferrer">
                        {item.title}
                      </a>
                    ) : (
                      item.title
                    )}
                  </h3>
                  {isFirstAuthor ? <span class="effort-pill effort-first-author">First Author</span> : null}
                </div>
                <p class="meta">
                  {venue} · {item.year}
                </p>
                <p>{item.abstract}</p>
              </article>
            );
          })}
        </div>
      </details>
    </section>

    <section class="section reveal-target" id="interests" data-progress-section="interests">
      <div class="section-header">
        <h2>Interests</h2>
      </div>
      <div class="card reveal-target">
        <ul class="tags">
          {interests.map((item: string) => (
            <li class="tag">{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <footer class="footer">
      <span>© {new Date().getFullYear()} {name}</span>
      <a href={resume} download>Download Resume</a>
    </footer>
  </main>

  <script>
    const expSection = document.querySelector("[data-exp-mode]");
    const expViewButtons = document.querySelectorAll("[data-exp-view]");
    const setExperienceMode = (mode) => {
      if (!expSection) return;
      expSection.setAttribute("data-exp-mode", mode);
      expViewButtons.forEach((button) => {
        const isActive = button.getAttribute("data-exp-view") === mode;
        button.classList.toggle("is-active", isActive);
      });
    };
    expViewButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const next = button.getAttribute("data-exp-view");
        if (next) setExperienceMode(next);
      });
    });

    const expToggle = document.querySelector("[data-exp-toggle]");
    const extras = document.querySelectorAll(".experience-extra");
    expToggle?.addEventListener("click", () => {
      const hidden = extras[0]?.classList.contains("is-hidden");
      extras.forEach((el) => el.classList.toggle("is-hidden", !hidden));
      if (expToggle) expToggle.textContent = hidden ? "Show less" : "See more";
    });

    document.querySelectorAll("details.collapse[data-filter]").forEach((section) => {
      const toggles = section.querySelectorAll("[data-first-author-toggle]");
      const items = section.querySelectorAll(".filter-item");
      let mode = "all";
      const applyFilter = () => {
        const onlyFirstAuthor = mode === "first";
        items.forEach((item) => {
          const isFirstAuthor = item.getAttribute("data-first-author") === "true";
          const show = !onlyFirstAuthor || isFirstAuthor;
          item.classList.toggle("is-hidden", !show);
        });
      };
      toggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          mode = toggle.getAttribute("data-filter-mode") ?? "all";
          toggles.forEach((item) => item.classList.remove("is-active"));
          toggle.classList.add("is-active");
          applyFilter();
        });
      });
      applyFilter();
    });

    const progressSections = document.querySelectorAll("[data-progress-section]");
    const progressLinks = document.querySelectorAll("[data-progress-link]");
    if (progressSections.length && progressLinks.length) {
      const setActiveProgress = (id) => {
        progressLinks.forEach((link) => {
          const isActive = link.getAttribute("data-progress-link") === id;
          link.classList.toggle("is-active", isActive);
        });
      };
      const getCurrentProgressId = () => {
        const marker = window.scrollY + Math.min(window.innerHeight * 0.32, 260);
        let current = progressSections[0]?.getAttribute("data-progress-section");
        progressSections.forEach((section) => {
          if (section.offsetTop <= marker) {
            current = section.getAttribute("data-progress-section");
          }
        });
        return current;
      };
      const syncProgress = () => {
        const current = getCurrentProgressId();
        if (current) setActiveProgress(current);
      };
      let ticking = false;
      const handleScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          syncProgress();
          ticking = false;
        });
      };
      progressLinks.forEach((link) => {
        link.addEventListener("click", () => {
          const id = link.getAttribute("data-progress-link");
          if (id) setActiveProgress(id);
          setTimeout(syncProgress, 220);
        });
      });
      window.addEventListener("scroll", handleScroll, { passive: true });
      window.addEventListener("resize", handleScroll);
      window.addEventListener("hashchange", syncProgress);
      syncProgress();
    }

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealTargets = document.querySelectorAll(".reveal-target");
    if (reduceMotion || !("IntersectionObserver" in window)) {
      revealTargets.forEach((item) => item.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.14, rootMargin: "0px 0px -8% 0px" },
      );
      revealTargets.forEach((item) => observer.observe(item));
    }
  </script>
</BaseLayout>
